APP_MODE=production
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgres://habeshago_user:change-me@db.example.com:5432/habeshago

# Auth and sessions
JWT_SECRET=replace-with-secret-manager-value
JWT_ISSUER=habeshago
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
ADMIN_MFA_REQUIRED=true

# Payments: real integrations must use provider dashboards, webhook signatures, and settlement reconciliation.
PAYMENT_PROVIDER_MODE=production
TELEBIRR_MERCHANT_ID=
TELEBIRR_API_KEY=
CBE_BIRR_MERCHANT_ID=
CBE_BIRR_API_KEY=
CHAPA_SECRET_KEY=
SANTIMPAY_MERCHANT_ID=
SANTIMPAY_PRIVATE_KEY=
PAYMENT_WEBHOOK_SECRET=

# SMS and push
SMS_PROVIDER_MODE=production
SMS_PROVIDER_API_KEY=
PUSH_PROVIDER_MODE=production
FIREBASE_SERVICE_ACCOUNT_JSON=

# Maps and location
MAPS_PROVIDER_MODE=openstreetmap
OPENSTREETMAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
ETHIOPIA_ADDRESS_INTELLIGENCE_MODE=pilot

# Security, compliance, and observability
SECRET_MANAGER_PROVIDER=
LEGAL_APPROVAL_REFERENCE=
AUDIT_LOG_RETENTION_DAYS=2555
LOG_LEVEL=info
ERROR_TRACKING_DSN=
METRICS_EXPORTER=
